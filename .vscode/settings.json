{
  "files.exclude": {
    "_site": true,
    ".jekyll-cache": true,
  },
  "pasteImage.path": "${projectRoot}/assets/images",
  "pasteImage.filePathConfirmInputBoxMode": "onlyName",
  "pasteImage.showFilePathConfirmInputBox": true,
  "pasteImage.insertPattern": "<img src=\"/assets/images/${imageFileName}\" alt=\"alt text\"/>",
  "pasteImage.encodePath": "none",
  "pasteImage.basePath": "${projectRoot}/assets/images",
  "cSpell.words": [
    "Appender",
    "bfseries",
    "Didier",
    "documentclass",
    "endcsname",
    "endraw",
    "eqref",
    "Hanon",
    "ifcsname",
    "includegraphics",
    "interlinepenalty",
    "invs",
    "marginparwidth",
    "markdownify",
    "mathbb",
    "newcommand",
    "newtheorem",
    "newtheoremstyle",
    "numberwithin",
    "openmode",
    "operatorname",
    "Pano",
    "parbox",
    "postdisplaypenalty",
    "predisplaypenalty",
    "providetheorem",
    "qedhere",
    "raggedright",
    "realsn",
    "recompiles",
    "relint",
    "renewcommand",
    "scriptsize",
    "SHARC",
    "showlabelfont",
    "showlabels",
    "showlabelsetlabel",
    "Slagle",
    "Subequations",
    "subjectto",
    "Subsubsction",
    "synctex",
    "theoremstyle",
    "Tickables",
    "ttfamily",
    "underfull",
    "upshape",
    "usepackage"
  ], 
  "dryerLint.ruleSets": {
    "paulwintz.com Markdown Rules": {
      "language": "markdown",
      // "glob": "*",
      "rules": {
          "Must have empty code line before or after display equation delimiter \"$$\" ": {
          "pattern": [
            // This pattern matches any "$$" that does not have an empty line before it and a nonempty line after it.
            "[^ \\r\\n\\t][ \\t]*\\r?\\n?[ \\t]*\\$\\$(?![ \\t]*\\r?\\n[ \\t]*(?:\\r?\\n|$))"
          ], 
          "maxLines": 3
          // Non-matching Test cases:
          // 
          //  $$ 
          //  h_1(x) \geq 0,~h_2(x) \geq 0,~\dots,~h_{p-1}(x) \geq 0,~h_p(x) \geq 0.
          //  $$
          //  
          //  $$ h_1(x) \geq 0,~h_2(x) \geq 0,~\dots,~h_{p-1}(x) \geq 0,~h_p(x) \geq 0.$$ 
          // 
          // Non-matching Test cases:
          // 
          //  text
          //  $$
          //  h_1(x) \geq 0,~h_2(x) \geq 0,~\dots,~h_{p-1}(x) \geq 0,~h_p(x) \geq 0.
          //  $$
          //  text
          //  
          //  text $$ h_1(x) \geq 0,~h_2(x) \geq 0,~\dots,~h_{p-1}(x) \geq 0,~h_p(x) \geq 0.$$ 
          //  text
          },
          "Markdown Headers Start with H2": {
            "pattern": [
              "^# "
            ],
            "message": "Start with 2nd level headers \"##\", since the page title is formatted with a level one header.",
            "fix": "## "
          },
        }, 
    },
  },
  "ltex.enabled": [
    "bibtex",
    "context",
    "context.tex",
    "html",
    "latex",
    "markdown",
    "mdx",
    "typst",
    "asciidoc",
    "neorg",
    "org",
    "quarto",
    "restructuredtext",
    "rsweave"
  ]
}